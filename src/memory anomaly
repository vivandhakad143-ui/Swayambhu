#!/bin/bash

# ============================================================
# Swayambhu Layer 3 : Memory Anomaly + Audit Protection
# FINAL EDITION - Zero Gap Protection
# Author: Swayambhu Security Framework
#
# Patches:
# [v1.0] Base memory monitoring
# [v2.0-P1] mlockall() detection via VmLck
# [v2.0-P2] ptrace POKEDATA via TracerPid
# [v2.0-P3] Fake kworker detection
# [v3.0-P1] Silent CCTV Attack prevention
# [v3.0-P2] Auditd process guardian
# [v3.0-P3] Rule deletion attempt detection
# [v3.1-P1] inotifywait INSTANT rule restore (Zero Gap!)
# ============================================================

LOG_FILE="/tmp/swayambhu_layer3_v3.1.log"
ALERT_COUNT=0
RULES_HASH_FILE="/tmp/.swayambhu_rules_hash"
AUDIT_RULES_BACKUP="/tmp/.swayambhu_audit_rules.bak"
RESTORE_LOCK="/tmp/.swayambhu_restore.lock"

# Thresholds
MEM_THRESHOLD=80
PROC_MEM_THRESHOLD=500
MLOCKED_THRESHOLD=10240

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
BLUE='\033[0;34m'
ORANGE='\033[0;33m'
NC='\033[0m'

echo -e "${GREEN}[+] Swayambhu Layer 3 v3.1: FINAL Edition Active...${NC}" | tee -a $LOG_FILE
echo -e "${PURPLE}[*] Zero-Gap Audit Protection Loaded${NC}" | tee -a $LOG_FILE
echo "[*] Timestamp: $(date)" | tee -a $LOG_FILE
echo "-------------------------------------------" | tee -a $LOG_FILE

# ============================================================
# HELPER: Restore audit rules
# ============================================================
restore_rules() {
    # Prevent restore loop with lock file
    if [ -f "$RESTORE_LOCK" ]; then
        return
    fi
    touch "$RESTORE_LOCK"

    echo -e "${YELLOW}[~] Restoring audit rules...${NC}" | tee -a $LOG_FILE
    auditctl -D 2>/dev/null

    if [ -f "$AUDIT_RULES_BACKUP" ]; then
        while IFS= read -r rule; do
            auditctl $rule 2>/dev/null
        done < "$AUDIT_RULES_BACKUP"
    fi

    # Reload rules file if exists
    if [ -f "/etc/audit/audit.rules" ]; then
        auditctl -R /etc/audit/audit.rules 2>/dev/null
    fi

    # Update hash
    auditctl -l 2>/dev/null | md5sum | awk '{print $1}' > "$RULES_HASH_FILE"

    rm -f "$RESTORE_LOCK"
    echo -e "${GREEN}[+] Rules restored at: $(date)${NC}" | tee -a $LOG_FILE
}

# ============================================================
# INIT: Setup audit rules & store hash at startup
# ============================================================
init_audit_protection() {
    echo -e "${BLUE}[INIT] Setting up audit rules...${NC}" | tee -a $LOG_FILE

    CRITICAL_RULES=(
        "-a always,exit -F arch=b64 -S ptrace -S mmap"
        "-a always,exit -F arch=b64 -S open -S openat -F exit=-EACCES"
        "-a always,exit -F arch=b64 -S kill -S tkill"
        "-w /etc/audit/audit.rules -p wa -k audit_rules_modified"
        "-w /etc/passwd -p wa -k passwd_modified"
        "-w /etc/shadow -p wa -k shadow_modified"
    )

    for rule in "${CRITICAL_RULES[@]}"; do
        auditctl $rule 2>/dev/null
    done

    # Backup rules
    auditctl -l > "$AUDIT_RULES_BACKUP" 2>/dev/null

    # Store hash
    auditctl -l 2>/dev/null | md5sum | awk '{print $1}' > "$RULES_HASH_FILE"

    # Make immutable
    if [ -f "/etc/audit/audit.rules" ]; then
        chattr +i /etc/audit/audit.rules 2>/dev/null
        echo -e "${GREEN}[INIT] Audit rules locked as immutable${NC}" | tee -a $LOG_FILE
    fi

    echo -e "${GREEN}[INIT] Rules hash: $(cat $RULES_HASH_FILE)${NC}" | tee -a $LOG_FILE
}

# ============================================================
# HELPER: Verify kworker authenticity
# ============================================================
verify_kworker() {
    local pid=$1
    local is_fake=0

    exe_path=$(readlink "/proc/$pid/exe" 2>/dev/null)
    [ -n "$exe_path" ] && is_fake=1

    heap=$(grep "\[heap\]" "/proc/$pid/maps" 2>/dev/null)
    [ -n "$heap" ] && is_fake=1

    threads=$(grep "^Threads:" "/proc/$pid/status" 2>/dev/null | awk '{print $2}')
    [ -n "$threads" ] && [ "$threads" -gt 1 ] && is_fake=1

    net_socks=$(ls /proc/$pid/fd 2>/dev/null | xargs -I{} readlink /proc/$pid/fd/{} 2>/dev/null | grep socket)
    [ -n "$net_socks" ] && is_fake=1

    echo $is_fake
}

# ============================================================
# [v3.0] Audit integrity checks
# ============================================================
check_audit_rules_integrity() {
    current_hash=$(auditctl -l 2>/dev/null | md5sum | awk '{print $1}')
    stored_hash=$(cat "$RULES_HASH_FILE" 2>/dev/null)

    if [ "$current_hash" != "$stored_hash" ]; then
        ALERT_COUNT=$((ALERT_COUNT + 1))
        echo -e "${RED}[!] ALERT #$ALERT_COUNT: Audit rules tampered!${NC}" | tee -a $LOG_FILE
        restore_rules
    else
        echo -e "${GREEN}[+] Audit rules intact${NC}" | tee -a $LOG_FILE
    fi
}

check_auditd_process() {
    auditd_pid=$(pgrep auditd)
    if [ -z "$auditd_pid" ]; then
        ALERT_COUNT=$((ALERT_COUNT + 1))
        echo -e "${RED}[!] ALERT #$ALERT_COUNT: auditd killed! Restarting...${NC}" | tee -a $LOG_FILE
        service auditd restart 2>/dev/null || auditd 2>/dev/null
    else
        echo -e "${GREEN}[+] auditd running: PID $auditd_pid${NC}" | tee -a $LOG_FILE
    fi
}

# ============================================================
# [v3.1-P1] inotifywait REAL-TIME WATCHER
# Runs in background — ZERO GAP protection
# Ghost deletes rules → INSTANTLY detected & restored
# No more sleep 5 vulnerability!
# ============================================================
start_inotify_watcher() {
    echo -e "${ORANGE}[v3.1] Starting inotifywait real-time watcher...${NC}" | tee -a $LOG_FILE

    # Check if inotifywait is available
    if ! command -v inotifywait &>/dev/null; then
        echo -e "${YELLOW}[~] inotifywait not found. Installing...${NC}" | tee -a $LOG_FILE
        apt-get install -y inotify-tools 2>/dev/null || \
        pkg install inotify-tools 2>/dev/null
    fi

    # Watch audit rules file in background
    if [ -f "/etc/audit/audit.rules" ]; then
        (
            inotifywait -m -e modify,delete,move,attrib \
                /etc/audit/audit.rules \
                /etc/audit/ 2>/dev/null | \
            while read path event file; do
                ALERT_COUNT=$((ALERT_COUNT + 1))
                echo -e "${RED}[INSTANT ALERT] Audit file event: $event on $path$file${NC}" | tee -a $LOG_FILE
                echo "[*] Ghost attack detected at: $(date)" | tee -a $LOG_FILE
                restore_rules
                # Also alert via system logger
                logger "SWAYAMBHU CRITICAL: Audit rules tampered! Event: $event"
            done
        ) &

        INOTIFY_PID=$!
        echo -e "${GREEN}[v3.1] inotifywait watcher active! PID: $INOTIFY_PID${NC}" | tee -a $LOG_FILE
        echo -e "${GREEN}[v3.1] Sleep-5 gap ELIMINATED — Zero gap protection ON${NC}" | tee -a $LOG_FILE
    else
        echo -e "${YELLOW}[~] /etc/audit/audit.rules not found — watching /etc/audit/ dir${NC}" | tee -a $LOG_FILE
        (
            inotifywait -m -e modify,delete,create \
                /etc/audit/ 2>/dev/null | \
            while read path event file; do
                echo -e "${RED}[INSTANT ALERT] Audit dir event: $event $file${NC}" | tee -a $LOG_FILE
                restore_rules
                logger "SWAYAMBHU CRITICAL: Audit directory tampered!"
            done
        ) &
        INOTIFY_PID=$!
    fi

    # Also watch the hash file itself
    (
        inotifywait -m -e modify,delete \
            "$RULES_HASH_FILE" 2>/dev/null | \
        while read path event file; do
            echo -e "${RED}[INSTANT ALERT] Hash file tampered! Restoring...${NC}" | tee -a $LOG_FILE
            restore_rules
        done
    ) &
}

# ============================================================
# CLEANUP on exit
# ============================================================
cleanup() {
    echo -e "${YELLOW}[*] Swayambhu Layer 3 shutting down...${NC}" | tee -a $LOG_FILE
    # Remove immutable flag on exit
    chattr -i /etc/audit/audit.rules 2>/dev/null
    rm -f "$RESTORE_LOCK"
    kill $INOTIFY_PID 2>/dev/null
    exit 0
}
trap cleanup SIGINT SIGTERM

# ============================================================
# INITIALIZE
# ============================================================
init_audit_protection
start_inotify_watcher

# ============================================================
# MAIN MONITORING LOOP
# ============================================================
while true; do

    echo -e "${CYAN}[*] === Scan: $(date) ===${NC}" | tee -a $LOG_FILE

    # CHECK 1: Overall memory
    mem_total=$(grep MemTotal /proc/meminfo | awk '{print $2}')
    mem_available=$(grep MemAvailable /proc/meminfo | awk '{print $2}')
    mem_used=$((mem_total - mem_available))
    mem_percent=$((mem_used * 100 / mem_total))

    if [ "$mem_percent" -gt "$MEM_THRESHOLD" ]; then
        ALERT_COUNT=$((ALERT_COUNT + 1))
        echo -e "${RED}[!] ALERT #$ALERT_COUNT: High memory: $mem_percent%${NC}" | tee -a $LOG_FILE
    else
        echo -e "${GREEN}[+] Memory OK: $mem_percent%${NC}" | tee -a $LOG_FILE
    fi

    # CHECK 2: Per-process memory
    while read -r pid rss comm; do
        rss_mb=$((rss / 1024))
        if [ "$rss_mb" -gt "$PROC_MEM_THRESHOLD" ]; then
            ALERT_COUNT=$((ALERT_COUNT + 1))
            echo -e "${RED}[!] ALERT #$ALERT_COUNT: ${comm} using ${rss_mb}MB!${NC}" | tee -a $LOG_FILE
        fi
    done < <(ps aux --no-headers | awk '{print $2, $6, $11}')

    # CHECK 3: Anonymous executable mappings
    for pid in /proc/[0-9]*; do
        pid_num=$(basename $pid)
        if [ -f "$pid/maps" ]; then
            anon_exec=$(grep -E "rwxp" "$pid/maps" 2>/dev/null | grep "00000000-")
            if [ -n "$anon_exec" ]; then
                ALERT_COUNT=$((ALERT_COUNT + 1))
                proc_name=$(cat "$pid/comm" 2>/dev/null)
                echo -e "${RED}[!] ALERT #$ALERT_COUNT: Anon exec mapping! PID:$pid_num ($proc_name)${NC}" | tee -a $LOG_FILE
            fi
        fi
    done

    # [v2.0-P1] mlockall
    for pid in /proc/[0-9]*; do
        pid_num=$(basename $pid)
        if [ -f "$pid/status" ]; then
            vmlck=$(grep "^VmLck:" "$pid/status" 2>/dev/null | awk '{print $2}')
            if [ -n "$vmlck" ] && [ "$vmlck" -gt "$MLOCKED_THRESHOLD" ]; then
                ALERT_COUNT=$((ALERT_COUNT + 1))
                proc_name=$(cat "$pid/comm" 2>/dev/null)
                echo -e "${RED}[!] ALERT #$ALERT_COUNT: mlockall abuse! PID:$pid_num Locked:${vmlck}KB${NC}" | tee -a $LOG_FILE
                kill -9 $pid_num 2>/dev/null
            fi
        fi
    done

    # [v2.0-P2] ptrace
    for pid in /proc/[0-9]*; do
        pid_num=$(basename $pid)
        if [ -f "$pid/status" ]; then
            tracer_pid=$(grep "^TracerPid:" "$pid/status" 2>/dev/null | awk '{print $2}')
            if [ -n "$tracer_pid" ] && [ "$tracer_pid" -ne 0 ]; then
                tracer_name=$(cat "/proc/$tracer_pid/comm" 2>/dev/null)
                if ! echo "$tracer_name" | grep -qE "^(gdb|strace|ltrace)$"; then
                    ALERT_COUNT=$((ALERT_COUNT + 1))
                    victim_name=$(cat "$pid/comm" 2>/dev/null)
                    echo -e "${RED}[!] ALERT #$ALERT_COUNT: Unauthorized ptrace! $tracer_name → $victim_name${NC}" | tee -a $LOG_FILE
                    kill -9 $tracer_pid 2>/dev/null
                fi
            fi
        fi
    done

    # [v2.0-P3] Fake kworker
    for pid in /proc/[0-9]*; do
        pid_num=$(basename $pid)
        proc_name=$(cat "$pid/comm" 2>/dev/null)
        if echo "$proc_name" | grep -qE "^kworker|^kthread|^ksoftirq|^migration"; then
            is_fake=$(verify_kworker $pid_num)
            if [ "$is_fake" -eq 1 ]; then
                ALERT_COUNT=$((ALERT_COUNT + 1))
                echo -e "${RED}[!] ALERT #$ALERT_COUNT: FAKE kworker! PID:$pid_num${NC}" | tee -a $LOG_FILE
                kill -9 $pid_num 2>/dev/null
            fi
        fi
    done

    # [v3.0] Audit checks
    check_audit_rules_integrity
    check_auditd_process

    echo "[*] Cycle done | Alerts: $ALERT_COUNT | inotify PID: $INOTIFY_PID" | tee -a $LOG_FILE
    echo "-------------------------------------------" | tee -a $LOG_FILE

    sleep 5
done
